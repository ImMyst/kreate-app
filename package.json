{
  "name": "kreate-app",
  "version": "0.1.0",
  "private": true,
  "workspaces": {
    "catalog": {
      "effect": "^4.0.0-beta.66",
      "@effect/platform-bun": "^4.0.0-beta.66",
      "@effect/vitest": "4.0.0-beta.66",
      "@effect/language-service": "^0.86.1"
    }
  },
  "bin": {
    "create-kreate-app": "./dist/main.js",
    "kreate-app": "./dist/main.js"
  },
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "oxlint .",
    "format": "oxfmt . --write",
    "format:check": "oxfmt . --check",
    "build": "tsc",
    "dev": "bun run src/main.ts",
    "link:global": "bun run build && bun link",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky"
  },
  "dependencies": {
    "@effect/platform-bun": "catalog:",
    "effect": "catalog:"
  },
  "devDependencies": {
    "@effect/language-service": "catalog:",
    "@effect/vitest": "catalog:",
    "@types/bun": "^1.3.14",
    "husky": "^9.1.7",
    "oxfmt": "^0.49.0",
    "oxlint": "^1.64.0",
    "turbo": "^2.9.14",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "packageManager": "bun@1.3.14"
}
